# Reference values for Convex environment variables.
# Set these with `cd packages/convex && vp run convex:env -- set KEY value`.

# Required for WorkOS AuthKit server-side auth and JWT validation.
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx

# Optional. Enables OpenAI embeddings and semantic search.
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Optional. Used by wrapped AI actions when Google models are enabled.
GOOGLE_AI_API_KEY=AIza_xxxxxxxxxxxxx

# Optional script toggles for packages/convex/scripts/sync-docs.ts.
SYNC_ENV=development
DEBUG=false
