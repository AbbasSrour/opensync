# Reference values for Convex environment variables.
# Set these with `cd packages/api && vp run convex:env -- set KEY value`.

# Required for WorkOS AuthKit server-side auth and JWT validation.
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx

# Embeddings + semantic search. Any OpenAI-compatible /embeddings endpoint.
# Default below is Cloudflare Workers AI with @cf/baai/bge-m3 (1024 dims).
# EMBEDDING_DIMENSION must match the vector index dimensions in schema.ts.
EMBEDDING_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<account_id>/ai/v1
EMBEDDING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=@cf/baai/bge-m3
EMBEDDING_DIMENSION=1024

# RAG answer LLM. Any OpenAI-compatible /chat/completions endpoint.
# Default below is Pioneer with deepseek-ai/DeepSeek-V4-Flash.
LLM_BASE_URL=https://api.pioneer.ai/v1
LLM_API_KEY=pio_sk_xxxxxxxxxxxxx
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional. Used by wrapped AI actions when Google models are enabled.
GOOGLE_AI_API_KEY=AIza_xxxxxxxxxxxxx

# Optional script toggles for packages/api/scripts/sync-docs.ts.
SYNC_ENV=development
DEBUG=false
