# Copy this file to apps/website/.env.local for local website development.

# Convex deployment used by the React app.
VITE_CONVEX_URL=https://your-project-123.convex.cloud

# WorkOS AuthKit client-side settings.
VITE_WORKOS_CLIENT_ID=client_xxxxxxxxxxxxx
VITE_REDIRECT_URI=http://localhost:5173/callback

# Backend variables are configured separately in Convex.
# See packages/convex/.env.example for the required Convex environment values.
