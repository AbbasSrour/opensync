{
  "name": "@opensync/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "opensync": "dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "vp pack src/index.ts --format esm --dts --clean",
    "install:local": "vp run build && bun link",
    "test": "vp test",
    "test:status": "bun dist/index.mjs status",
    "test:queue": "bun dist/index.mjs queue inspect --source opencode"
  },
  "dependencies": {
    "@opensync/adapter-opencode": "workspace:*",
    "@opensync/kit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
